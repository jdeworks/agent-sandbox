#!/usr/bin/env bash
# List connected scan volumes from scan-volumes.json (no compose parsing).
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
VOLUMES_FILE="${1:-$SCRIPT_DIR/scan-volumes.json}"

if [[ ! -f "$VOLUMES_FILE" ]]; then
  echo '{"volumes":[]}' > "$VOLUMES_FILE"
fi

node -e "
const fs = require('fs');
const d = JSON.parse(fs.readFileSync(process.argv[1], 'utf8'));
const vols = d.volumes || [];
if (vols.length === 0) {
  console.log('No scan volumes connected.');
  console.log('Add one with: ./add-volume <name> [host-path]');
  process.exit(0);
}
console.log('Connected scan volumes:');
vols.forEach(v => console.log('  ', v.name, '->', v.mountPath));
" "$VOLUMES_FILE"
