{
  "name": "@security-analyzer/worker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src",
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test-job": "ts-node src/scripts/test-job.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@security-analyzer/types": "*",
    "@security-analyzer/common": "*",
    "bullmq": "^5.1.0",
    "dotenv": "^16.4.0",
    "ioredis": "^5.3.2",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.11.0",
    "ts-node": "^10.9.2",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.12",
    "ts-jest": "^29.1.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["<rootDir>/src"],
    "testMatch": ["**/__tests__/**/*.ts", "**/*.test.ts", "**/*.spec.ts"],
    "moduleFileExtensions": ["ts", "tsx", "js", "jsx", "json", "node"],
    "collectCoverageFrom": ["src/services/**/*.ts"],
    "coverageDirectory": "coverage"
  }
}
