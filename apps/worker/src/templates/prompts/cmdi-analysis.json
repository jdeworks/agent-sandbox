{
  "name": "cmdi-analysis",
  "description": "Specialized template for Command Injection vulnerability analysis",
  "version": "1.0.0",
  "extends": "exploit-analysis",
  "variables": {
    "REPO": "Repository name",
    "BRANCH": "Branch name",
    "FILE": "File path",
    "LINE": "Line number",
    "CATEGORY": "CMDi",
    "SEVERITY": "Severity level",
